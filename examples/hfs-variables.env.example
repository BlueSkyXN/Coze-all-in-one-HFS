# Recommended Hugging Face Space Variables / Secrets.
# Put secrets such as API keys in Secrets, not public Variables.

# Public URL: usually generated automatically from SPACE_HOST.
# COZE_PUBLIC_URL=https://your-space-username-your-space-name.hf.space

DISABLE_USER_REGISTRATION=true
ALLOW_REGISTRATION_EMAIL=you@example.com

# Model API: OpenAI-compatible example.
MODEL_PROTOCOL_0=openai
MODEL_OPENCOZE_ID_0=100001
MODEL_NAME_0=example-model
MODEL_ID_0=example-model
MODEL_BASE_URL_0=https://your-openai-compatible-endpoint/v1
MODEL_API_KEY_0=replace-me

BUILTIN_CM_TYPE=openai
BUILTIN_CM_OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
BUILTIN_CM_OPENAI_API_KEY=replace-me
BUILTIN_CM_OPENAI_MODEL=example-model

# Storage: prefer S3/TOS/ImageX for public HTTPS URLs.
# FILE_UPLOAD_COMPONENT_TYPE=storage
# STORAGE_TYPE=s3
# STORAGE_UPLOAD_HTTP_SCHEME=https
# S3_ACCESS_KEY=replace-me
# S3_SECRET_KEY=replace-me
# S3_ENDPOINT=https://...
# S3_BUCKET_ENDPOINT=https://...
# S3_REGION=...
# STORAGE_BUCKET=opencoze
# ENABLE_LOCAL_MINIO=0

# Knowledge/RAG: built-in Elasticsearch + Milvus is the default all-in-one path.
# Only set these when overriding to external managed services.
# ES_ADDR=https://your-es-endpoint
# ES_VERSION=v8
# ES_USERNAME=...
# ES_PASSWORD=...
# VECTOR_STORE_TYPE=vikingdb
# VIKING_DB_HOST=...
# VIKING_DB_REGION=...
# VIKING_DB_AK=...
# VIKING_DB_SK=...
# VIKING_DB_SCHEME=https
# EMBEDDING_TYPE=openai
# OPENAI_EMBEDDING_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_EMBEDDING_API_KEY=replace-me
